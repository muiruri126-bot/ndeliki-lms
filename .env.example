# ── NDELIKI LMS — Railway Environment Variables ──
# Set these in Railway Dashboard → Service → Variables

NODE_ENV=production
PORT=3000

# Database (auto-set via start.sh to use volume mount)
DATABASE_URL=file:/data/ndeliki.db

# JWT (CHANGE THESE! Use strong random strings, 32+ chars)
JWT_ACCESS_SECRET=CHANGE_ME_USE_RANDOM_32_CHAR_STRING_HERE
JWT_REFRESH_SECRET=CHANGE_ME_USE_ANOTHER_RANDOM_32_CHAR_STR

JWT_ACCESS_EXPIRY=15m
JWT_REFRESH_EXPIRY=7d

# CORS — set to your Railway public URL (e.g. https://your-app.up.railway.app)
CORS_ORIGINS=https://your-app.up.railway.app

# Encryption key (32 chars)
ENCRYPTION_KEY=0123456789abcdef0123456789abcdef

# File Storage
STORAGE_TYPE=local
UPLOAD_DIR=./uploads

# Logging
LOG_LEVEL=info
