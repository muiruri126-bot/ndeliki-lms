# ── Server ──
NODE_ENV=development
PORT=3000
APP_VERSION=1.0.0

# ── Database ──
DATABASE_URL=postgresql://ndeliki:ndeliki_dev_pass@localhost:5432/ndeliki_lms

# ── JWT ──
JWT_SECRET=change-me-to-a-real-256-bit-secret-in-production
JWT_REFRESH_SECRET=change-me-to-another-256-bit-secret
JWT_ACCESS_EXPIRY=15m
JWT_REFRESH_EXPIRY=7d

# ── CORS ──
CORS_ORIGINS=http://localhost:5173,http://localhost:3001

# ── Encryption (AES-256 key for PII fields) ──
ENCRYPTION_KEY=0123456789abcdef0123456789abcdef

# ── Email (SendGrid / SMTP) ──
SMTP_HOST=smtp.sendgrid.net
SMTP_PORT=587
SMTP_USER=apikey
SMTP_PASS=your-sendgrid-api-key
EMAIL_FROM=noreply@ndeliki.co.ke
EMAIL_FROM_NAME=Ndeliki Limited

# ── SMS (Africa's Talking) ──
AT_API_KEY=your-africastalking-api-key
AT_USERNAME=sandbox
AT_SENDER_ID=NDELIKI

# ── File Storage ──
STORAGE_TYPE=local
UPLOAD_DIR=./uploads
# For S3:
# STORAGE_TYPE=s3
# AWS_ACCESS_KEY_ID=xxx
# AWS_SECRET_ACCESS_KEY=xxx
# AWS_REGION=eu-west-1
# AWS_S3_BUCKET=ndeliki-documents

# ── Sentry (Error Tracking) ──
# SENTRY_DSN=https://xxx@sentry.io/xxx

# ── Logging ──
LOG_LEVEL=debug
